# ────────────────────────────────────────────────────────────
#  FlowSight — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env — it is in .gitignore.
# ────────────────────────────────────────────────────────────

# Node server port (Railway injects this automatically in production)
PORT=5000

# MongoDB Atlas connection string
# Create a free cluster at: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=<AppName>
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Google Gemini API Key
# Generate at: https://aistudio.google.com/app/apikey
# Model in use: gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here
